{
    "extends": "@tala-tools/tsconfig/base.json",
    "display": "Svelte",
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "svelte",
        "noUnusedLocals": false,
        "module": "preserve",
        "target": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": false,
        "emitDeclarationOnly": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["./src/**/*", "./tests/**/*", "./svelte.config.js", "./vitest.config.ts"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "scripts"]
}
