{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Core Build",
    "compilerOptions": {
        "outDir": "./dist",
        "noEmit": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declarationDir": "dist/types",
        "declaration": true,
        "emitDeclarationOnly": true,
        "allowSyntheticDefaultImports": true,
        "target": "ESNext",
        "types": ["node"],
        "rootDir": "src",
        "importHelpers": true,
        "isolatedModules": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "jsx": "preserve"
    },
    "include": ["./src/**/*"],
    "exclude": ["dist", "build", "./src/scripts", "node_modules", ".vscode", ".turbo"]
}
