{
    "extends": "@tala-tools/tsconfig/base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["./src/**/*", "./src/**/*.json", "vite.config.ts"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "**/*.test.ts", "src/scripts"]
}
