{
    "name": "@solar-icons/nuxt",
    "version": "2.0.0-beta.0",
    "description": "Nuxt module for easily integrating Solar Icons into your Nuxt 3+ applications.",
    "keywords": [
        "nuxt",
        "nuxt-module",
        "icons",
        "solar-icons",
        "ui",
        "design-system"
    ],
    "homepage": "https://github.com/saoudi-h/solar-icons/tree/main/packages/nuxt#readme",
    "bugs": {
        "url": "https://github.com/saoudi-h/solar-icons/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saoudi-h/solar-icons.git",
        "directory": "packages/nuxt"
    },
    "license": "MIT",
    "author": "Hakim Saoudi <saoudihakim@gmail.com>",
    "contributors": [],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/types.d.mts",
            "import": "./dist/module.mjs"
        },
        "./icons": {
            "types": "./dist/runtime/icons.d.ts",
            "import": "./dist/runtime/icons.js"
        },
        "./icons/*": {
            "types": "./dist/runtime/icons/*.d.ts",
            "import": "./dist/runtime/icons/*.js"
        },
        "./dynamic": {
            "types": "./dist/runtime/dynamic.d.ts",
            "import": "./dist/runtime/dynamic.js"
        },
        "./lib": {
            "types": "./dist/runtime/lib.d.ts",
            "import": "./dist/runtime/lib.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "main": "./dist/module.mjs",
    "typesVersions": {
        "*": {
            ".": [
                "./dist/types.d.mts"
            ],
            "icons": [
                "./dist/runtime/icons.d.ts"
            ],
            "icons/*": [
                "./dist/runtime/icons/*.d.ts"
            ],
            "dynamic": [
                "./dist/runtime/dynamic.d.ts"
            ],
            "lib": [
                "./dist/runtime/lib.d.ts"
            ]
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "LICENSE-THIRD-PARTY"
    ],
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "prepack": "node scripts/build-entries.mjs && nuxt-module-build build",
        "copy:licenses": "cp ../../LICENSE ./LICENSE && cp ../../LICENSE-THIRD-PARTY ./LICENSE-THIRD-PARTY",
        "build": "nuxt-module-build prepare && node scripts/build-entries.mjs && nuxt-module-build build && pnpm copy:licenses",
        "dev": "pnpm dev:prepare && nuxi dev playground",
        "dev:build": "nuxi build playground",
        "dev:prepare": "node scripts/build-entries.mjs && nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
        "release": "pnpm lint && pnpm test && pnpm prepack && changelogen --release && pnpm publish && git push --follow-tags",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
        "clean": "rm -rf node_modules .nuxt dist"
    },
    "dependencies": {
        "@nuxt/kit": "^4.4.8",
        "@solar-icons/vue": "workspace:*"
    },
    "devDependencies": {
        "@nuxt/devtools": "4.0.0-alpha.7",
        "@nuxt/eslint-config": "^1.16.0",
        "@nuxt/module-builder": "^1.0.2",
        "@nuxt/schema": "^4.4.8",
        "@nuxt/test-utils": "^4.0.3",
        "@types/node": "latest",
        "changelogen": "^0.6.2",
        "eslint": "^10.6.0",
        "nuxt": "^4.4.8",
        "typescript": "~6.0.3",
        "vitest": "^4.1.10",
        "vue-tsc": "3.3.7"
    }
}
