{
    "extends": "@tala-tools/tsconfig/react-library.json",
    "compilerOptions": {
        "noUnusedLocals": false,
        "module": "ESNext",
        "declarationMap": true,
        "allowJs": false,
        "checkJs": false,
        "incremental": true,
        "isolatedDeclarations": false,
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": ["./src/**/*"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "scripts", "tests"]
}
