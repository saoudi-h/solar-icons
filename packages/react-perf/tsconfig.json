{
    "extends": "@tala-tools/tsconfig/react-library.json",
    "compilerOptions": {
        "noUnusedLocals": false,
        "module": "ESNext",
        "declarationMap": true,
        "allowJs": false,
        "checkJs": false,
        "incremental": true,
        "isolatedDeclarations": true,
        "moduleResolution": "Bundler",
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": [
        "./src/**/*",
        "vite.config.ts",
        "./scripts/**/*",
        "tsdown.config.ts",
        "./tests/**/*"
    ],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo"]
}
