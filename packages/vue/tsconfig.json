{
    "extends": "@tala-tools/tsconfig/base.json",
    "display": "Vue",
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "noUnusedLocals": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["node", "vite/client"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": [
        "./src/lib",
        "./src/*.ts",
        "./src/*.d.ts",
        "./src/*.vue",
        "tsdown.config.ts",
        "tsdown.nuxt.config.ts",
        "./scripts/**/*.ts",
        "vitest.config.ts",
        "lint-staged.config.mjs",
        "env.d.ts",
        "vitest.setup.ts",
        "__tests__/**/*.ts",
        "__tests__/**/*.vue"
    ],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "src/icons/**/*.ts"]
}
