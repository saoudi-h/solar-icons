{
    "extends": "@tala-tools/tsconfig/react-library.json",
    "compilerOptions": {
        "noUnusedLocals": false,
        "module": "ESNext",
        "declarationMap": true,
        "allowJs": false,
        "checkJs": false,
        "incremental": true,
        "isolatedDeclarations": false,
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "noEmit": true
    },
    "include": ["./src/**/*", "./scripts/**/*", "./tests/**/*", "./tsdown.config.ts", "./vitest.config.ts"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo"]
}
