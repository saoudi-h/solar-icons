{
    "extends": "@tala-tools/tsconfig/react-library.json",
    "compilerOptions": {
        "noUnusedLocals": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["./src/**/*", "vite.config.ts", "./scripts/**/*"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo"]
}
