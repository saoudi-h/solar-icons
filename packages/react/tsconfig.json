{
    "extends": "@tala-tools/tsconfig/react-library.json",
    "compilerOptions": {
        "noUnusedLocals": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["./src/**/*"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "scripts"]
}
