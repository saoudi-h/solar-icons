{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "declaration": true,
        "sourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "types": []
    },
    "angularCompilerOptions": {
        "compilationMode": "partial"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["**/*.spec.ts"]
}
