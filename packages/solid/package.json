{
  "name": "@solar-icons/solid",
  "version": "2.0.0-beta.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Solar Icons for SolidJS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saoudi-h/solar-icons.git",
    "directory": "packages/solid"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSE-THIRD-PARTY"
  ],
  "scripts": {
    "build": "pnpm generate:assets && pnpm copy:licenses && tsdown -l error",
    "copy:licenses": "cp ../../LICENSE ./LICENSE && cp ../../LICENSE-THIRD-PARTY ./LICENSE-THIRD-PARTY",
    "generate:assets": "tsx scripts/generate-assets.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*\" --ignore-unknown --list-different",
    "format:fix": "prettier \"**/*\" --ignore-unknown --write",
    "clean": "rimraf *.tsbuildinfo node_modules build dist",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "pre-commit": "lint-staged"
  },
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./lib": {
      "types": "./dist/lib/index.d.mts",
      "import": "./dist/lib/index.mjs"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.mts",
      "import": "./dist/lib/*.mjs"
    },
    "./dynamic": {
      "types": "./dist/icons/dynamic/index.d.mts",
      "import": "./dist/icons/dynamic/index.mjs"
    },
    "./dynamic/*": {
      "types": "./dist/icons/dynamic/*.d.mts",
      "import": "./dist/icons/dynamic/*.mjs"
    },
    "./*": {
      "types": "./dist/icons/style/*.d.mts",
      "import": "./dist/icons/style/*.mjs"
    },
    "./bold/*": {
      "types": "./dist/icons/bold/*.d.mts",
      "import": "./dist/icons/bold/*.mjs"
    },
    "./bold-duotone/*": {
      "types": "./dist/icons/bold-duotone/*.d.mts",
      "import": "./dist/icons/bold-duotone/*.mjs"
    },
    "./broken/*": {
      "types": "./dist/icons/broken/*.d.mts",
      "import": "./dist/icons/broken/*.mjs"
    },
    "./line-duotone/*": {
      "types": "./dist/icons/line-duotone/*.d.mts",
      "import": "./dist/icons/line-duotone/*.mjs"
    },
    "./linear/*": {
      "types": "./dist/icons/linear/*.d.mts",
      "import": "./dist/icons/linear/*.mjs"
    },
    "./outline/*": {
      "types": "./dist/icons/outline/*.d.mts",
      "import": "./dist/icons/outline/*.mjs"
    }
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@solar-icons/core": "workspace:*",
    "@tala-tools/eslint": "0.1.4",
    "@tala-tools/prettier": "0.0.3",
    "@tala-tools/tsconfig": "0.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^26.1.1",
    "babel-preset-solid": "^1.9.12",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.14",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "unplugin-solid": "^1.0.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "solid-js": ">= 1.6.0"
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "solid",
    "solidjs",
    "icons",
    "svg",
    "solar",
    "design",
    "interface",
    "UI",
    "UX"
  ],
  "author": {
    "name": "Saoudi Hakim",
    "url": "https://hakimsaoudi.dev",
    "email": "saoudihakim@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/saoudi-h/solar-icons/issues"
  }
}
