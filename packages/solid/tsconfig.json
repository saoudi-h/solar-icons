{
    "extends": "@tala-tools/tsconfig/base.json",
    "display": "Solid",
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "noUnusedLocals": false,
        "module": "ESNext",
        "declarationMap": true,
        "allowJs": false,
        "checkJs": false,
        "incremental": true,
        "isolatedDeclarations": false,
        "isolatedModules": true,
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "noEmit": true
    },
    "include": ["./src/**/*", "./tests/**/*", "./tsdown.config.ts"],
    "exclude": ["dist", "build", "node_modules", ".vscode", ".turbo", "scripts"]
}
