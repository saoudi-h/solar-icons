{
    "extends": "@tala-tools/tsconfig/base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "types": ["node"],
        "allowImportingTsExtensions": true
    },
    "include": ["./scripts/**/*", "./tests/**/*", "./vitest.config.ts", "./tsdown.config.ts"],
    "exclude": ["dist", "node_modules", "LICENSE", "LICENSE-THIRD-PARTY"]
}
