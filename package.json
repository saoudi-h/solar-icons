{
    "name": "solar",
    "private": true,
    "description": "Solar Icons",
    "type": "module",
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "format": "turbo format",
        "format:fix": "turbo format:fix",
        "clean": "turbo clean && rimraf node_modules",
        "version": "changeset version",
        "version-packages": "changeset version && pnpm install --no-frozen-lockfile",
        "release": "changeset publish",
        "typecheck": "turbo typecheck",
        "spell": "cspell \"**/*\" --no-progress",
        "prepare": "husky",
        "test": "turbo test",
        "pre-commit": "turbo pre-commit --concurrency=1",
        "setup": "pnpm install && pnpm build"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@commitlint/types": "^21.0.1",
        "@tala-tools/eslint": "0.1.3",
        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/eslint": "^9.6.1",
        "@types/node": "^25.9.3",
        "@typescript/native-preview": "7.0.0-dev.20260611.2",
        "cspell": "^10.0.1",
        "eslint": "^10.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^4.1.0",
        "publint": "^0.3.21",
        "rimraf": "^6.1.3",
        "tsdown": "^0.22.2",
        "tsx": "^4.22.4",
        "turbo": "^2.9.18",
        "typescript": "^6.0.3",
        "unplugin-unused": "^0.5.7",
        "vite-tsconfig-paths": "^6.1.1"
    },
    "packageManager": "pnpm@11.5.3",
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/saoudi-h/solar.git"
    },
    "keywords": [
        "react",
        "icons",
        "svg",
        "solar",
        "design",
        "interface",
        "phosphor",
        "UI",
        "UX"
    ],
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "license": "MIT",
    "dependencies": {
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.31.0"
    }
}
