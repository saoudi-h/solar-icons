{
    "name": "@solar-icons/docs",
    "version": "0.0.1-beta.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "dev": "next dev --turbo",
        "start": "next start",
        "postinstall": "fumadocs-mdx",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "typecheck": "tsc --noEmit",
        "typecheck:scripts": "tsc -p tsconfig.scripts.json",
        "clean": "rimraf *.tsbuildinfo node_modules build dist .turbo .next",
        "generate:hero:utils": "tsx ./core/scripts/generateHeroUtils.ts",
        "generate:data": "tsx ./core/scripts/generate-data.ts",
        "generate:descriptions": "tsx ./core/scripts/generate-descriptions.ts",
        "lint-staged": "lint-staged",
        "lint:links": "fumadocs-mdx && bun scripts/lint.ts",
        "analyze": "ANALYZE=true pnpm run build"
    },
    "dependencies": {
        "@calcom/cal-sans-ui": "^1.3.0",
        "@number-flow/react": "^0.6.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@solar-icons/react": "1.1.0",
        "@types/file-saver": "^2.0.7",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "1.1.1",
        "file-saver": "^2.0.5",
        "framer-motion": "^12.38.0",
        "fumadocs-core": "^16.8.8",
        "fumadocs-mdx": "^14.3.2",
        "fumadocs-typescript": "^5.2.6",
        "fumadocs-ui": "^16.8.8",
        "fuse.js": "^7.3.0",
        "jotai": "^2.20.0",
        "lenis": "^1.3.23",
        "lucide-react": "^1.14.0",
        "next": "16.2.5",
        "next-themes": "^0.4.6",
        "nuqs": "^2.8.8",
        "octokit": "^5.0.3",
        "react": "^19.2.6",
        "react-colorful": "^5.7.0",
        "react-dom": "^19.2.6",
        "react-select": "^5.10.1",
        "react-virtualized": "^9.22.5",
        "sonner": "^2.0.6",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-screens": "^1.1.0",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@iconify/react": "^6.0.0",
        "@next/bundle-analyzer": "^16.2.5",
        "@solar-icons/core": "workspace:*",
        "@tala-tools/eslint": "0.1.0",
        "@tala-tools/prettier": "0.0.2",
        "@tala-tools/tsconfig": "0.0.1",
        "@tailwindcss/postcss": "^4.2.4",
        "@types/mdx": "^2.0.13",
        "@types/node": "25.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-virtualized": "^9.22.0",
        "eslint-plugin-better-tailwindcss": "^4.5.0",
        "next-validate-link": "^1.6.6",
        "postcss": "^8.5.14",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.2.4",
        "tsx": "^4.21.0"
    }
}
