{
    "name": "@solar-icons/docs",
    "version": "0.0.1-beta.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/generate-changelog.ts && next build",
        "dev": "next dev --turbo",
        "start": "next start",
        "postinstall": "fumadocs-mdx",
        "lint": "eslint . && pnpm lint:links",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "typecheck": "tsgo --noEmit",
        "typecheck:scripts": "tsc -p tsconfig.scripts.json",
        "clean": "rimraf *.tsbuildinfo node_modules build dist .turbo .next",
        "generate:hero:utils": "tsx ./core/scripts/generateHeroUtils.ts",
        "generate:data": "tsx ./core/scripts/generate-data.ts",
        "generate:descriptions": "tsx ./core/scripts/generate-descriptions.ts",
        "lint-staged": "lint-staged",
        "pre-commit": "lint-staged",
        "lint:links": "fumadocs-mdx && bun scripts/lint.ts",
        "analyze": "ANALYZE=true pnpm run build"
    },
    "dependencies": {
        "@calcom/cal-sans-ui": "^1.3.0",
        "@number-flow/react": "^0.6.0",
        "@radix-ui/react-dialog": "^1.1.16",
        "@radix-ui/react-dropdown-menu": "^2.1.17",
        "@radix-ui/react-popover": "^1.1.16",
        "@radix-ui/react-select": "^2.3.0",
        "@radix-ui/react-separator": "^1.1.9",
        "@radix-ui/react-slider": "^1.4.0",
        "@radix-ui/react-slot": "^1.2.5",
        "@radix-ui/react-tabs": "^1.1.14",
        "@radix-ui/react-toggle": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.9",
        "@solar-icons/react": "^1.1.1",
        "@types/file-saver": "^2.0.7",
        "babel-plugin-react-compiler": "1.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "1.1.1",
        "file-saver": "^2.0.5",
        "framer-motion": "^12.40.0",
        "fumadocs-core": "^16.10.3",
        "fumadocs-mdx": "^15.0.12",
        "fumadocs-typescript": "^5.2.6",
        "fumadocs-ui": "^16.10.3",
        "fuse.js": "^7.4.2",
        "jotai": "^2.20.1",
        "lenis": "^1.3.23",
        "lucide-react": "^1.18.0",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "nuqs": "^2.8.9",
        "octokit": "^5.0.5",
        "react": "^19.2.7",
        "react-colorful": "^5.7.0",
        "react-dom": "^19.2.7",
        "react-select": "^5.10.2",
        "react-virtualized": "^9.22.6",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-screens": "^1.1.2",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@iconify/react": "^6.0.2",
        "@next/bundle-analyzer": "^16.2.9",
        "@solar-icons/core": "workspace:*",
        "@tailwindcss/postcss": "^4.3.1",
        "@tala-tools/eslint": "0.1.4",
        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@types/mdx": "^2.0.14",
        "@types/node": "25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-virtualized": "^9.22.3",
        "eslint-plugin-better-tailwindcss": "^4.6.0",
        "next-validate-link": "^1.6.6",
        "postcss": "^8.5.15",
        "sharp": "^0.35.1",
        "tailwindcss": "^4.3.1"
    }
}
