{
  "name": "svelte-app",
  "version": "2.0.0-beta.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean": "rm -rf node_modules .svelte-kit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*\" --ignore-unknown --list-different",
    "format:fix": "prettier \"**/*\" --ignore-unknown --write",
    "generate:icons": "tsx scripts/generate-icon-list.ts",
    "typecheck": "tsgo --noEmit",
    "pre-commit": "lint-staged"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tala-tools/eslint": "0.1.4",
    "@tala-tools/prettier": "0.0.3",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "type": "module",
  "dependencies": {
    "@solar-icons/svelte": "workspace:*"
  }
}
