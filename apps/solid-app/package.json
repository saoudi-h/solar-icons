{
    "name": "solid-app",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "clean": "rm -rf node_modules dist",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "typecheck": "tsgo --noEmit",
        "generate:icons": "tsx scripts/generate-icon-list.ts",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@solar-icons/solid": "workspace:*",
        "solid-js": "^1.9.13"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@tala-tools/eslint": "0.1.3",
        "@tala-tools/prettier": "0.0.3",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vite-plugin-solid": "^2.11.12"
    }
}
