{
    "name": "solid-app",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "clean": "rm -rf node_modules dist",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "typecheck": "tsc --noEmit",
        "generate:icons": "tsx scripts/generate-icon-list.ts",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@solar-icons/solid": "workspace:*",
        "solid-js": "^1.9.7"
    },
    "devDependencies": {
        "@tala-tools/eslint": "0.1.0",
        "@tala-tools/prettier": "0.0.2",
        "@tailwindcss/vite": "^4.2.4",
        "tailwindcss": "^4.2.4",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.11",
        "vite-plugin-solid": "^2.11.6"
    }
}
